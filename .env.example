# Echo Audit V2 — environment variables
# Copy to .env for local development. In production, set these in Railway.

# Postgres connection string. Railway provides this automatically when the
# Postgres plugin is attached. If unset, the app falls back to local SQLite
# (echoaudit.db) for development.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, app.py auto-generates a random one per process — fine for local dev,
# fatal in prod (sessions invalidate on every restart).
SECRET_KEY=change-me-to-a-long-random-hex-string

# Fernet key for encrypting stored VoIP provider credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for the VoIP feature. Leave blank if you're not using VoIP yet.
VOIP_ENCRYPTION_KEY=

# Anthropic API key — used by the grader, clarifying questions, rubric AI,
# performance reports, and per-location pre-call briefs.
ANTHROPIC_API_KEY=sk-ant-...

# AssemblyAI API key — used to transcribe uploaded call recordings.
ASSEMBLYAI_API_KEY=

# Display branding (optional). Defaults to "Echo Audit".
CLIENT_NAME=Echo Audit
CLIENT_FULL_NAME=Echo Audit

# Where uploaded call audio is written. Defaults to ./audio_uploads relative
# to the working directory. On Railway, point this at a mounted volume if you
# need durable storage across deploys.
AUDIO_DIR=./audio_uploads

# HTTP port. Railway sets PORT automatically; leave unset locally to use 5000.
PORT=5000

# Set to any non-empty value to enable Flask debug mode. Never set in prod.
FLASK_DEBUG=

# AI caller service — outbound HTTP target for "Schedule AI Shop" on the grade
# page. Echo Audit POSTs to {AI_CALLER_BASE_URL}/calls/initiate with a Bearer
# token. Required when /api/grade/ai-shop is in use; safe to leave unset
# otherwise (the route surfaces a clear 502 with sc_status='failed').
AI_CALLER_BASE_URL=https://ai-caller-service-production.up.railway.app
AI_CALLER_AUTH_TOKEN=

# ElevenLabs API key for fetching post-call audio bytes after grading completes.
# Echo Audit calls GET https://api.elevenlabs.io/v1/convai/conversations/{id}/audio
# in a background daemon thread once an ElevenLabs interaction is graded, then
# writes the MP3 onto interactions.interaction_audio_data so the existing
# audio player on /app/history/<id> can serve it. Failure to fetch is logged
# but doesn't affect the grade. Global to Echo Audit (ElevenLabs exposes one
# set of API keys per workspace today; multi-tenant would require per-tenant
# key storage). Generate at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ElevenLabs Conversational AI agent ID for outbound shop calls. Get from
# the ElevenLabs dashboard's Conversational AI section. The agent's
# configuration (first message, voice, prompt, language) lives in the
# ElevenLabs dashboard and is not configured here.
ELEVENLABS_AGENT_ID=

# ElevenLabs phone number ID — points to the Twilio number registered to
# the agent inside ElevenLabs' dashboard. Get from the ElevenLabs
# dashboard's Phone Numbers section. ElevenLabs handles the Twilio
# integration internally; we don't need Twilio credentials directly.
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
