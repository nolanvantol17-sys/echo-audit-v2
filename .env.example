# Echo Audit V2 — environment variables
# Copy to .env for local development. In production, set these in Railway.

# Postgres connection string. Railway provides this automatically when the
# Postgres plugin is attached. If unset, the app falls back to local SQLite
# (echoaudit.db) for development.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, app.py auto-generates a random one per process — fine for local dev,
# fatal in prod (sessions invalidate on every restart).
SECRET_KEY=change-me-to-a-long-random-hex-string

# Fernet key for encrypting stored VoIP provider credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for the VoIP feature. Leave blank if you're not using VoIP yet.
VOIP_ENCRYPTION_KEY=

# Anthropic API key — used by the grader, clarifying questions, rubric AI,
# performance reports, and per-location pre-call briefs.
ANTHROPIC_API_KEY=sk-ant-...

# AssemblyAI API key — used to transcribe uploaded call recordings.
ASSEMBLYAI_API_KEY=

# Display branding (optional). Defaults to "Echo Audit".
CLIENT_NAME=Echo Audit
CLIENT_FULL_NAME=Echo Audit

# Where uploaded call audio is written. Defaults to ./audio_uploads relative
# to the working directory. On Railway, point this at a mounted volume if you
# need durable storage across deploys.
AUDIO_DIR=./audio_uploads

# HTTP port. Railway sets PORT automatically; leave unset locally to use 5000.
PORT=5000

# Set to any non-empty value to enable Flask debug mode. Never set in prod.
FLASK_DEBUG=
